<UserControl x:Class="InsuranceBrokerSystem.UI.Views.Clients.ClientRegistry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InsuranceBrokerSystem.UI.Views.Clients"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000" 
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch">

    <UserControl.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter Section -->
        <GroupBox Header="Filter By" Style="{StaticResource GroupBoxStyle}" >
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status -->
                <!-- Status Checkboxes - Using Modern Style -->
                <GroupBox Header="Status" Style="{StaticResource GroupBoxStyle}" Margin="0,0,0,0">
                    <WrapPanel Width="285">
                        <CheckBox x:Name="chProspect" 
                                  Content="Prospect" 
                                  IsChecked="True"
                                  Style="{StaticResource ModernCheckBoxStyle}"
                                  Background="#FFE9DC62" Width="100" />
                        <!-- Keep background if you want colored label -->


                        <CheckBox x:Name="ChActive" 
                                  Content="Active" 
                                  IsChecked="True"
                                  Style="{StaticResource ModernCheckBoxStyle}"
                                  Background="#FF599A1A" Width="100"/>

                        <CheckBox x:Name="ChBlocked" 
                                  Content="Blocked"
                                  Style="{StaticResource ModernCheckBoxStyle}"
                                  Background="Gray" Width="100"/>

                        <CheckBox x:Name="chRejected" 
                                  Content="Rejected" 
                                  Style="{StaticResource ModernCheckBoxStyle}"
                                  Background="#FFCC2F1D" Width="100"/>
                    </WrapPanel>
                </GroupBox>

                <!-- Filters -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1 -->
                    <Label Content="ID" VerticalAlignment="Center" Margin="4" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtClientID" Height="28" Margin="5,0,120,0" Grid.Column="1"
                             Background="Black" Foreground="LawnGreen" FontWeight="Bold"
                             HorizontalContentAlignment="Left"/>

                    <Label Content="Name" Grid.Row="1" Grid.Column="0" Margin="4" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtClientName" Grid.Row="1" Grid.Column="1" Width="230" Height="28" Margin="4" IsReadOnly="True"/>

                    <Button Content="Search..." Grid.Column="1" Height="28" Margin="141,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}" Background="{StaticResource RefreshGray}" Click="btnSearch_Click"/>

                    <!-- Row 2 -->
                    <Label Content="Producer" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="4" HorizontalAlignment="Right"/>
                    <ComboBox x:Name="CombProducers" Grid.Row="2" Grid.Column="1" Width="230" Height="28" Margin="4"/>

                    <Label Content="CR No." Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="4" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtCRNo" Grid.Row="1" Grid.Column="3" Width="230" Height="28" Margin="4"/>

                    <Label Content="Account No." Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="4" HorizontalAlignment="Right"/>
                    <TextBox x:Name="txtAccNo" Grid.Row="0" Grid.Column="3" Width="230" Height="28" Margin="4"/>

                    <!--<Label Content="Branch" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="4" HorizontalAlignment="Right"/>
                    <ComboBox x:Name="CombBranch" Grid.Row="3" Grid.Column="1" Width="230" Height="28" Margin="4" />-->

                    <Label Content="Type" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="4" HorizontalAlignment="Right"/>
                    <ComboBox x:Name="ComboType" Grid.Row="2" Grid.Column="3" Width="230" Height="28" Margin="4" >
                        <ComboBoxItem Content="--All--"/>
                        <ComboBoxItem Content="Corporate"/>
                        <ComboBoxItem Content="Retail"/>
                    </ComboBox>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Register Button -->
        <StackPanel Orientation="Horizontal" Margin="15,5,15,15" Grid.Row="1">
            <Button Content="+ Register New Client"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="18,9" 
                    Background="{StaticResource SaveButtonColor}"
                    Click="btnRegisterNewClient_Click"/>
        </StackPanel>

        <!-- DataGrid Section -->
        <StackPanel Grid.Row="2" Margin="10,0,10,0">
            <!-- Header -->
            <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,9">
                <DockPanel>
                    <TextBlock Text="Client's List" 
                               Foreground="White" 
                               FontWeight="Bold" 
                               FontSize="15"
                               VerticalAlignment="Center"/>

                    <Button Content="Refresh 🔄" 
                            HorizontalAlignment="Right" 
                            Background="#3498DB" 
                            Padding="12,4" 
                            Foreground="White"
                            Click="btnRefresh_Click"/>
                </DockPanel>
            </Border>

            <!-- DataGrid -->
            <DataGrid x:Name="GridClients"
                      ItemsSource="{Binding Clients}" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA"
                      RowHeight="38"
                      GridLinesVisibility="None"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Client ID" Binding="{Binding ClientID}" Width="85"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" 
                                        ElementStyle="{StaticResource StatusColumnStyle}"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2.2*"/>
                    <DataGridTextColumn Header="Account No. Premium" Binding="{Binding AccountNoPremium}" Width="155"/>
                    <DataGridTextColumn Header="Account No. VAT" Binding="{Binding AccountNoVAT}" Width="135"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="95"/>
                    <DataGridTextColumn Header="Branch" Binding="{Binding Branch}" Width="120"/>
                    <DataGridTextColumn Header="Producer (Salesman)" Binding="{Binding Producer}" Width="2*"/>
                    <DataGridTextColumn Header="Identity No." Binding="{Binding IdentityNo}" Width="130"/>
                    <DataGridTextColumn Header="CR No." Binding="{Binding CRNo}" Width="130"/>
                    <DataGridTextColumn Header="Unified No." Binding="{Binding UnifiedNo}" Width="120" Visibility="Collapsed"/>
                    <DataGridTextColumn Header="Saved By" Binding="{Binding CreateBy}" Width="145"/>
                    <DataGridTextColumn Header="Saved On" Binding="{Binding CreateOn}" Width="135"/>

                    <!-- Action Columns -->
                    <DataGridTemplateColumn Header="Print" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Print" 
                                        Style="{StaticResource SecondaryButtonStyle}" 
                                        Margin="3"
                                        Click="PrintButton_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Edit" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Edit" 
                                        Style="{StaticResource SecondaryButtonStyle}" 
                                        Margin="3"
                                        />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="15,12,15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Results found: " 
                           Foreground="Blue" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="lblResult" 
                           Text="00" 
                           Foreground="Blue" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Export to Excel" 
                        Width="165" 
                        Height="38" 
                        Margin="8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="#27AE60"
                        Click="btnExportExcel_Click"/>

                <Button Content="Print List" 
                        Width="125" 
                        Height="38" 
                        Margin="8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="#3498DB"
                        Click="btnPrintList_Click"/>

                <Button Content="Close" 
                        Width="110" 
                        Height="38" 
                        Margin="8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="#E74C3C"
                        Click="btnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
