<Window x:Class="InsuranceBrokerSystem.UI.Views.Clients.ClientSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InsuranceBrokerSystem.UI.Views.Clients"
        mc:Ignorable="d"
        Title="Search Client" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Section -->
        <GroupBox Header="Search Client" Style="{StaticResource GroupBoxStyle}" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Content="Client ID:" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtSearchId" Grid.Column="1" Height="28" Margin="5" 
                         TextChanged="txtSearchId_TextChanged"/>

                <Label Content="Client Name:" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtSearchName" Grid.Column="3" Height="28" Margin="5"
                         TextChanged="txtSearchName_TextChanged"/>

                <Button x:Name="btnSearch" Grid.Column="4" Content="Search" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="{StaticResource SaveButtonColor}"
                        Margin="5" Padding="15,5" Click="btnSearch_Click"/>
            </Grid>
        </GroupBox>

        <!-- Results Section -->
        <GroupBox Header="Search Results" Style="{StaticResource GroupBoxStyle}" 
                  Grid.Row="1" Margin="10,5,10,5">
            <DataGrid x:Name="dgSearchResults"
                      ItemsSource="{Binding SearchResults}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F8F9FA"
                      RowHeight="35"
                      GridLinesVisibility="None"
                      CanUserSortColumns="True"
                      MouseDoubleClick="dgSearchResults_MouseDoubleClick">
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding ClientName}" Width="2*"/>
                    <DataGridTextColumn Header="Identity No." Binding="{Binding IdentityNo}" Width="150"/>
                    <DataGridTextColumn Header="CR No." Binding="{Binding CommercialRegistrationNo}" Width="150"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding ClientType}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Buttons Section -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="10">
            <Button x:Name="btnSelect" Content="Select" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Background="{StaticResource SaveButtonColor}"
                    Width="100" Height="35" Margin="5"
                    Click="btnSelect_Click"/>
            <Button x:Name="btnCancel" Content="Cancel" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Background="#E74C3C"
                    Width="100" Height="35" Margin="5"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
