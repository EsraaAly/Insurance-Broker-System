<Window x:Class="InsuranceBrokerSystem.UI.Views.Financial.AccountFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InsuranceBrokerSystem.UI.Views.Financial"
        Title="Account Form" Height="461" Width="400" MinHeight="500" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow">
    <Window.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Text="Account Details" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <!-- Account Type -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Account Type *" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbAccountType" SelectedItem="{Binding Type}" Padding="8" Background="White" BorderBrush="#CBD5E1" Height="45"/>
        </StackPanel>

        <!-- Account Name -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Account Name *" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtAccountName" Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}" Padding="8" Background="White" BorderBrush="#CBD5E1" Height="45"/>
        </StackPanel>

        <!-- Description -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Description" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" MinHeight="60" Padding="8" Background="White" BorderBrush="#CBD5E1"/>
        </StackPanel>

        <!-- Is Postable -->
        <CheckBox Grid.Row="4" Content="Is Postable (Leaf Node)" IsChecked="{Binding IsPostable}" Foreground="#334155" FontSize="14" Margin="0,5,0,20"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,10">
            <Button Content="Save" Click="BtnSave_Click" Padding="20,10" Style="{StaticResource GridUpdateButton}" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Width="72"/>

            <Button Content="Cancel" Click="BtnCancel_Click" Padding="20,10" Style="{StaticResource GridDeleteButton}"  BorderBrush="#CBD5E1"  Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
