<UserControl x:Class="InsuranceBrokerSystem.UI.Views.Financial.ApproveInsuranceCompany"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InsuranceBrokerSystem.UI.Views.Financial"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" Padding="15" Margin="10" CornerRadius="8">
            <StackPanel Orientation="Horizontal">
                <GroupBox Header="Current Status" Margin="0,0,25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChPending" Content="Pending" IsChecked="{Binding IsPending}" Margin="10,0"/>
                        <CheckBox x:Name="ChRejected" Content="Rejected" IsChecked="{Binding IsRejected}" Margin="10,0"/>
                    </StackPanel>
                </GroupBox>

                <Label Content="Name" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtCompanyName" Width="300" Height="28" Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}"/>

            </StackPanel>
        </Border>
        
        <!--<GroupBox Header="Insurance Companies List" Grid.Row="1" Style="{StaticResource GroupBoxStyle}">-->
        <StackPanel Grid.Row="2">
            <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8" Height="47">
                <DockPanel>
                    <TextBlock Text="Insurance Companies List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button x:Name="btnRefresh" Content="Refresh 🔄" HorizontalAlignment="Right" Background="#3498DB" Padding="10,2" Foreground="White" Click="btnRefresh_Click"/>
                </DockPanel>
            </Border>
            <DataGrid x:Name="CompaniesGrid" ItemsSource="{Binding InsuranceCompanies}" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="2*" Visibility="Collapsed"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" ElementStyle="{StaticResource StatusColumnStyle}"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding CompanyName}" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tele." Binding="{Binding Tele}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    <DataGridTextColumn Header="VAT No." Binding="{Binding VATNo}" Width="100"/>
                    <DataGridTextColumn Header="CR No" Binding="{Binding CRNo}" Width="2*"/>
                    <DataGridTextColumn Header="Abbreviation" Binding="{Binding Abbreviation}" Width="100"/>

                    <DataGridTemplateColumn Header="Approve" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Name="btnApprove" Content="Approve" Style="{StaticResource GridUpdateButton}"  CommandParameter="{Binding}" Margin="2" Click="btnApprove_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Reject" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Name="btnReject" Content="Reject" Style="{StaticResource GridDeleteButton}" CommandParameter="{Binding}" Margin="2" Click="btnReject_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Grid Grid.Row="3" Margin="10,15,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Results found: " Foreground="Blue" FontWeight="Bold"/>
                <TextBlock Text="{Binding InsuranceCompanies.Count, FallbackValue=00}" Foreground="Blue" FontWeight="Bold"/>
            </StackPanel>

            <Button x:Name="Close" Content="Close" HorizontalAlignment="Right" Width="100" Margin="10"
                    Background="{StaticResource AccentBrush}" 
                    Style="{StaticResource {x:Type Button}}"  Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
