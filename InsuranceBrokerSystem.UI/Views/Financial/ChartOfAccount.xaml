<UserControl x:Class="InsuranceBrokerSystem.UI.Views.Financial.ChartOfAccount"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"             
             xmlns:local="clr-namespace:InsuranceBrokerSystem.UI.Views.Financial"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.Resources>

        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
    
        <Border Grid.Column="0" Style="{StaticResource PremiumCardStyle}" Margin="20" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="📖 Chart of Accounts" FontSize="20" FontWeight="Bold" Foreground="{StaticResource MainNavy}" Margin="5,0,0,15"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="50,-5,10,0">
                        <Button Content="🔄 Refresh" Padding="14,8" Click="BtnLoad_Click" 
                            Background="{StaticResource ActionSecondaryBg}" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Width="113">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
                


                <Border Grid.Row="1" CornerRadius="20" BorderThickness="1.5" BorderBrush="{StaticResource ModernInputBorder}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="18,0,5,0" Foreground="{StaticResource ModernTextMuted}" FontSize="14"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox" Background="Transparent" BorderThickness="0" Padding="5,12" FontSize="14" Foreground="{StaticResource ModernTextPrimary}" VerticalContentAlignment="Center" FontWeight="Medium"/>
                        
                        <TextBlock Grid.Column="1" IsHitTestVisible="False" Text="Search accounts..." VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource ModernTextMuted}" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                
    
                <TreeView Grid.Row="2" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch"
                            ItemsSource="{Binding AccountNodes}" x:Name="tvAccounts" SelectedItemChanged="tvAccounts_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <!-- Hide default WPF selection blue rectangles -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>

                        <HierarchicalDataTemplate DataType="{x:Type local:Account}" ItemsSource="{Binding Children}">
                            <Border x:Name="NodeBorder" CornerRadius="8" Padding="6,4" Margin="0,2" MinWidth="260" Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon based on Postable logic -->
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="📁"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPostable}" Value="True">
                                                    <Setter Property="Text" Value="📄"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Premium Badge for Account Number -->
                                <Border Grid.Column="1" Background="{StaticResource ModernInputBgReadOnly}" CornerRadius="6" Padding="8,4" Margin="0,0,10,0" BorderThickness="1" BorderBrush="{StaticResource ModernInputBorder}">
                                    <TextBlock Text="{Binding AccountNumber}" FontWeight="Bold" Foreground="{StaticResource ActionInfoBg}" FontSize="13" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Account Name -->
                                <TextBlock Grid.Column="2" Text="{Binding AccountName}" Foreground="{StaticResource ModernTextSecondary}" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                <!-- Quick Action Buttons -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0,0,0">
                                    <Button Content="➕" Width="26" Height="26" Margin="2" Background="{StaticResource ActionSuccessBg}" Foreground="White" BorderThickness="0" Click="BtnAddChild_Click" Tag="{Binding}" ToolTip="Add Sub-Account" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="13"/>
                                            </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="0.7"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding CanAddChild}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    
                                    
                                    <Button Content="🗑️" Width="26" Height="26" Margin="2" Background="{StaticResource ActionDangerBg}" Foreground="White" BorderThickness="0" Click="BtnDelete_Click" Tag="{Binding}" ToolTip="Delete Account" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="13"/>
                                            </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="0.7"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.3"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            </Border>
                            <HierarchicalDataTemplate.Triggers>
                                <!-- Hover Style -->
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                    <Setter TargetName="NodeBorder" Property="Background" Value="#F8FAFC"/>
                                </DataTrigger>
                                <!-- Selected Style -->
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                    <Setter TargetName="NodeBorder" Property="Background" Value="#EFF6FF"/>
                                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#93C5FD"/>
                                    <Setter TargetName="NodeBorder" Property="Cursor" Value="Hand"/>
                                </DataTrigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Grid>
        </Border>

        
     <!--Right Side: Metrics & Form--> 
    
        <Grid Grid.Column="1" Margin="0,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
     <!--Metrics UniformGrid--> 
    
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,20">
                <Border Style="{StaticResource PremiumCardStyle}" Margin="0,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="💼 Total Assets" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="SAR 1,250" FontSize="17" FontWeight="Bold" Foreground="#2563EB" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PremiumCardStyle}" Margin="5,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📉 Liabilities" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="SAR 450,20" FontSize="17" FontWeight="Bold" Foreground="#DC2626" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PremiumCardStyle}" Margin="5,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="📈 Net Equity" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="SAR 799,80" FontSize="17" FontWeight="Bold" Foreground="#059669" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PremiumCardStyle}" Margin="5,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="💰 Revenue" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="SAR 1,250" FontSize="17" FontWeight="Bold" Foreground="#D97706" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PremiumCardStyle}" Margin="5,0,0,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="🧾 Expenses" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="SAR 250,00" FontSize="17" FontWeight="Bold" Foreground="#7C3AED" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!--Main Form Card-->
            <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="25" Margin="0,10,0,0">
                <DockPanel LastChildFill="True">
                    
                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource ModernInputBorder}" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,20">
                        <DockPanel>
                            <TextBlock Text="⚙️ Account Information" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource MainNavy}" VerticalAlignment="Center"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="+ Add Root Account" IsEnabled="{Binding CanAddRoot}" Background="{StaticResource ActionSuccessBg}" Click="BtnAddRoot_Click" FontWeight="SemiBold" Foreground="White" BorderThickness="0" Padding="15,8" Margin="0,0,0,0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="10,12">
                                    <Label Content="Account Code" Foreground="{StaticResource ModernTextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedAccount.AccountNumber}" BorderThickness="1.5" IsReadOnly="True" Background="{StaticResource ModernInputBgReadOnly}" BorderBrush="{StaticResource ModernInputBorder}" Padding="12,0" Height="42" VerticalContentAlignment="Center" Foreground="{StaticResource ModernTextPrimary}" FontWeight="Medium"/>
                                </StackPanel>
                                <StackPanel Margin="10,12">
                                    <Label Content="Parent Account" Foreground="{StaticResource ModernTextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedAccount.ParentName}" IsReadOnly="True" Background="{StaticResource ModernInputBgReadOnly}" BorderThickness="1.5" BorderBrush="{StaticResource ModernInputBorder}" Padding="12,0" Height="42" VerticalContentAlignment="Center" Foreground="{StaticResource ModernTextPrimary}" FontWeight="Medium"/>
                                </StackPanel>
                                <StackPanel Margin="10,12">
                                    <Label Content="Account Type *" Foreground="{StaticResource ModernTextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedAccount.Type}" IsReadOnly="True" Background="{StaticResource ModernInputBgReadOnly}" BorderThickness="1.5" BorderBrush="{StaticResource ModernInputBorder}" Padding="12,0" Height="42" VerticalContentAlignment="Center" Foreground="{StaticResource ModernTextPrimary}" FontWeight="Medium"/>
                                </StackPanel>
                                <StackPanel Margin="10,12">
                                    <Label Foreground="{StaticResource ModernTextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4">
                                        <TextBlock>Account Name (EN)</TextBlock>
                                    </Label>
                                    <TextBox x:Name="txtAccountName" Text="{Binding SelectedAccount.AccountName}" Padding="12,0" Height="42" Background="White" BorderThickness="1.5" BorderBrush="{StaticResource ModernInputBorderActive}" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="10,12">
                                    <Label Content="Description *" Foreground="{StaticResource ModernTextSecondary}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtDescription" Text="{Binding SelectedAccount.Description}" TextWrapping="Wrap" MinHeight="42" Padding="12,8" Background="White" BorderThickness="1.5" BorderBrush="{StaticResource ModernInputBorderActive}" VerticalContentAlignment="Top"/>
                                </StackPanel>
                                <CheckBox x:Name="ChPostable" Content=" Is Postable" IsChecked="{Binding SelectedAccount.IsPostable}" Foreground="{StaticResource ModernTextPrimary}" FontWeight="Medium" FontSize="14" VerticalContentAlignment="Center" Margin="10,40,0,0"/>
                            </UniformGrid>

                            <!-- Bottom Actions -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,10,0">
                                <Button Content="✏️ Edit Details" Click="BtnEdit_Click" FontWeight="SemiBold" Foreground="White" BorderThickness="0" Padding="20,10" Background="{StaticResource ActionPrimaryBg}" Height="40">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
