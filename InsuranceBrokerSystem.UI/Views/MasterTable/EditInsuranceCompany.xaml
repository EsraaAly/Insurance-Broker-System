<Window x:Class="InsuranceBrokerSystem.UI.Views.MasterTable.EditInsuranceCompany"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:local="clr-namespace:InsuranceBrokerSystem.UI"
                mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1000" 
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" 
                WindowStartupLocation="CenterScreen" x:Name="EditInsuranceWindow">

    <Window.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="New Insurance Company" 
               FontSize="20" FontWeight="Bold" 
               Foreground="{StaticResource MainNavy}" 
               Margin="20,15,0,15"/>

        <TabControl Grid.Row="1" Margin="15,0,15,10" Background="White">

            <TabItem Header="General Details">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="10">
                            <Label Content="Name *"/>
                            <TextBox x:Name="txtName" Tag="Name"/>
                            <Label Content="Name (Arabic) *" IsEnabled="False"/>
                            <TextBox x:Name="txtNameArabic" Tag="NameArabic"/>
                            <Label Content="Abbreviation *"/>
                            <TextBox x:Name="txtAbbreviation" Tag="Abbr" Width="150" HorizontalAlignment="Left"/>
                            <Label Content="Tele. *"/>
                            <TextBox x:Name="txtTele" Tag="Tele"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10">
                            <Label Content="VAT No. *"/>
                            <TextBox x:Name="txtVATNo" Tag="VAT"/>
                            <Label Content="CR No. *"/>
                            <TextBox x:Name="txtCRNo" Tag="CR"/>
                            <Label Content="Unified No."/>
                            <TextBox x:Name="txtUnifiedNo" Tag="Unified"/>
                            <Label Content="Email"/>
                            <TextBox x:Name="txtEmail" Tag="Email"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Address Details">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <UniformGrid Columns="2" >
                        <StackPanel Margin="10">
                            <Label Content="Building No."/>
                            <TextBox x:Name="txtBuildingNo"/>
                            <Label Content="Building Name" />
                            <TextBox x:Name="txtBuildingName"/>
                            <Label Content="Street Name"/>
                            <TextBox x:Name="txtStreetName"/>
                            <Label Content="District Name"/>
                            <TextBox x:Name="txtDistrictName"/>
                            <Label Content="City Name"/>
                            <TextBox x:Name="txtCityName"/>
                            <Label Content="Country Region"/>
                            <TextBox x:Name="txtCountry"/>
                            <Label Content="State"/>
                            <TextBox x:Name="txtState"/>
                            <Label Content="Postal/ZIP Code"/>
                            <TextBox x:Name="txtPostalCode"/>
                        </StackPanel>
                        <StackPanel Margin="10">
                            <Label Content="Additional No."/>
                            <TextBox x:Name="txtAdditionalNo"/>
                            <Label Content="Building Name (Arabic)" />
                            <TextBox x:Name="txtBuildingNameArabic"/>
                            <Label Content="Street Name (Arabic)"/>
                            <TextBox x:Name="txtStreetlNameArabic"/>
                            <Label Content="District Name (Arabic)"/>
                            <TextBox x:Name="txtDistrictNameArabic"/>
                            <Label Content="City Name (Arabic)"/>
                            <TextBox x:Name="txtCityNameArabic"/>
                            <Label Content="Country Region (Arabic)"/>
                            <TextBox x:Name="txtCountryArabic"/>
                            <Label Content="State (Arabic)"/>
                            <TextBox x:Name="txtStateArabic"/>
                        </StackPanel>
                    </UniformGrid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Products &amp; Contacts" Height="32" VerticalAlignment="Top">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="00">
                        <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8">
                            <DockPanel>
                                <TextBlock Text="Products List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="+" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" CommandParameter="{Binding}" Padding="10,2" Foreground="White" Click ="btnAddProduct_Click"/>
                            </DockPanel>
                        </Border>
                        <DataGrid x:Name ="ProductsGrid" ItemsSource="{Binding Products}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.CanContentScroll="True" 
                                IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="2*" Visibility="Collapsed"/>
                                <!--<DataGridComboBoxColumn Header="Classes" Width="*" ItemsSource="{Binding DataContext.InsuranceClasses}"  SelectedValueBinding="{Binding ClassID,UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" DisplayMemberPath="ClassName"/>-->
                                <DataGridTemplateColumn Header="Classes"  Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox VerticalAlignment="Center" HorizontalAlignment="Stretch" ItemsSource="{Binding DataContext.InsuranceClasses,ElementName=EditInsuranceWindow}" SelectedValue="{Binding ClassId,UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" DisplayMemberPath="ClassName" SelectionChanged="ComboClass_SelectionChanged"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!--<DataGridComboBoxColumn Header="Line of Businesses" Width="*" ItemsSource="{Binding DataContext.LinesOfBusiness, RelativeSource={RelativeSource AncestorType=Window}}"/>-->
                                <DataGridTemplateColumn Header="Line of Businesses"  Width="*" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox VerticalAlignment="Center" 
                                                  HorizontalAlignment="Stretch" 
                                                  ItemsSource="{Binding avaiableLOBs}"
                                                  SelectedValue="{Binding LobId,UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Id" DisplayMemberPath="LineOfBusiness"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Action" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete" Style="{StaticResource GridDeleteButton}" CommandParameter="{Binding}" Click="DeleteProduct_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8">
                            <DockPanel>
                                <TextBlock Text="Contacts List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="+" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" CommandParameter="{Binding}" Padding="10,2" Foreground="White" Click ="btnAddContact_Click"/>
                            </DockPanel>
                        </Border>
                        <DataGrid x:Name="ContactsGrid"
                              ItemsSource="{Binding Contacts}"
                              CanUserAddRows="False"
                              AutoGenerateColumns="False" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.CanContentScroll="True"  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="2*" Visibility="Collapsed"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                                <DataGridTextColumn Header="Mobile No" Binding="{Binding Mobile}" Width="120"/>
                                <!--<DataGridComboBoxColumn Header="Department" Width="100" ItemsSource="{Binding DataContext.DepartmentList, RelativeSource={RelativeSource AncestorType=Window}}"  SelectedValueBinding="{Binding Department}">
                            </DataGridComboBoxColumn>-->
                                <DataGridTemplateColumn Header="Department"  Width="100" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox VerticalAlignment="Center" HorizontalAlignment="Stretch" ItemsSource="{Binding DataContext.DepartmentList,ElementName=EditInsuranceWindow}" SelectedValue="{Binding Department,UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Action" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete" Style="{StaticResource GridDeleteButton}" CommandParameter="{Binding}" Click="DeleteContact_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="White" Padding="15" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnUpdate" Content="Update" Width="100" Margin="5,0" Style="{StaticResource {x:Type Button}}" Background="{StaticResource SaveButtonColor}" Foreground="White" Click="btnUpdate_Click"/>
                <Button x:Name="btnClear" Content="Clear" Width="100" Margin="5,0" Style="{StaticResource SecondaryButtonStyle}" Background="{StaticResource SidebarColor}"  Click="btnClear_Click"/>
                <Button x:Name="btnClose"  Content="Close" Width="100" Margin="5,0" Style="{StaticResource {x:Type Button}}" Background="{StaticResource AccentBrush}" Foreground="White" Click="btnClose_Click"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>