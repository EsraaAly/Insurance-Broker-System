<UserControl x:Class="InsuranceBrokerSystem.UI.Views.MasterTable.InsuranceClassesRegistry"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InsuranceBrokerSystem.UI"
        mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000" 
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch" x:Name="RootUserControl" >

    <UserControl.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid Margin="20">
            <Border Background="White" CornerRadius="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <TabControl Background="Transparent" BorderThickness="0">

                    <!-- ================= TAB 1 ================= -->
                    <TabItem Header="Insurance Classes">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Group -->
                            <GroupBox Header="Class Details"  Margin="0,0,0,15">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Content="Insurance Type" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtInsuranceClass" Grid.Column="1" HorizontalAlignment="Stretch"/>

                                    <Label Content="Abbreviation" Grid.Column="2" VerticalAlignment="Center" Margin="20,0,10,0"/>
                                    <TextBox x:Name="txtAbbreviation" Grid.Column="3" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </GroupBox>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15">
                                <Button Content="Save" Width="120" Margin="0,0,10,0"  Background="{StaticResource SaveButtonColor}" Click ="SaveClass_Click"/>
                                <Button Content="Clear" Width="120" Style="{StaticResource SecondaryButtonStyle}"  Background="{StaticResource SidebarColor}" Click="ClearClass_Click"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8">
                                    <DockPanel>
                                        <TextBlock Text="Insurance Classes List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Content="Refresh 🔄" HorizontalAlignment="Right" Background="#3498DB" Padding="10,2" Foreground="White" Click ="BtnRefresh_Click"/>
                                    </DockPanel>
                                </Border>
                                <!-- Grid -->
                                <DataGrid x:Name="GridInsuranceClasses"

                              AutoGenerateColumns="False"
                              CanUserAddRows="False">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Visibility="Collapsed"/>
                                        <DataGridTextColumn Header="Insurance Type" Binding="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        <DataGridTextColumn Header="Abbreviation" Binding="{Binding Abbreviation, UpdateSourceTrigger=PropertyChanged}" Width="auto"/>

                                        <DataGridTemplateColumn Header="Update" >
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Update" Style="{StaticResource GridUpdateButton}" CommandParameter="{Binding}" Click="UpdateClass_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Delete">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Delete" Style="{StaticResource GridDeleteButton}" CommandParameter="{Binding}" Click="DeleteClass_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>

                                </DataGrid>
                            </StackPanel>
                        </Grid>

                    </TabItem>

                    <!-- ================= TAB 2 ================= -->
                    <TabItem Header="Line of Businesses" Height="32" VerticalAlignment="Top">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72*"/>
                                <ColumnDefinition Width="859*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <GroupBox Header="Lines Details" Margin="0,0,0,15" Grid.ColumnSpan="2">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Content="Class" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="CombClass" 
                                              Grid.Column="1" 
                                              Panel.ZIndex="99"
                                              IsHitTestVisible="True"
                                              VerticalContentAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              DisplayMemberPath="ClassName" 
                                              SelectedValuePath="Id" />

                                    <Label Content="Business Type" Grid.Column="2" VerticalAlignment="Center" Margin="20,0,10,0"/>
                                    <TextBox x:Name="txtLineOfBusiness" Grid.Column="3" HorizontalAlignment="Stretch"/>

                                    <Label Content="Abbreviation" Grid.Column="4" VerticalAlignment="Center" Margin="20,0,10,0"/>
                                    <TextBox x:Name="txtAbb" Grid.Column="5" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </GroupBox>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15" Grid.ColumnSpan="2">
                                <Button Content="Save" Width="120" Margin="0,0,10,0" Background="{StaticResource SaveButtonColor}" Click="SaveLine_Click"/>
                                <Button Content="Clear" Width="120" Style="{StaticResource SecondaryButtonStyle}"  Background="{StaticResource SidebarColor}" Click="ClearLine_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8" >
                                    <DockPanel>
                                        <TextBlock Text="Line of Business List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Content="Refresh 🔄" HorizontalAlignment="Right" Background="#3498DB" Padding="10,2" Foreground="White"/>
                                    </DockPanel>
                                </Border>

                                <DataGrid x:Name="GridLines"
                              AutoGenerateColumns="False" Grid.ColumnSpan="2">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"  Binding="{Binding Id}" Width="150" Visibility="Collapsed"/>
                                        <DataGridTextColumn Header="ClassID"  Binding="{Binding ClassID}" Width="150" Visibility="Collapsed"/>
                                        <!--<DataGridComboBoxColumn Header="Class Name" ItemsSource="{Binding DataContext.AllClassesList,ElementName=RootUserControl}" SelectedValueBinding="{Binding ClassID,UpdateSourceTrigger=PropertyChanged}"  SelectedValuePath="Id" DisplayMemberPath="ClassName" Width="250">
                                            <DataGridComboBoxColumn.ElementStyle>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="ItemsSource" Value="{Binding Path=DataContext.AllClassesList ,RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                                                </Style>
                                            </DataGridComboBoxColumn.ElementStyle>
                                            <DataGridComboBoxColumn.EditingElementStyle>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="ItemsSource" Value="{Binding Path=DataContext.AllClassesList, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                                                </Style>
                                            </DataGridComboBoxColumn.EditingElementStyle>
                                        </DataGridComboBoxColumn>-->
                                        <DataGridTemplateColumn Header="Class Name"  Width="250" >
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox  Width="245" VerticalAlignment="Center" HorizontalAlignment="Center" ItemsSource="{Binding DataContext.AllClassesList,ElementName=RootUserControl}" SelectedValue="{Binding ClassID,UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" DisplayMemberPath="ClassName"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Business Type" Binding="{Binding LineOfBusiness,UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        <DataGridTextColumn Header="Abbreviation" Binding="{Binding Abbreviation,UpdateSourceTrigger=PropertyChanged}" Width="100"/>

                                        <DataGridTemplateColumn Header="Update">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Update" Style="{StaticResource GridUpdateButton}" CommandParameter="{Binding}" Click="UpdateLine_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Delete">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Delete" Style="{StaticResource GridDeleteButton}" CommandParameter="{Binding}" Click="DeleteLine_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>

                    </TabItem>

                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>