<UserControl x:Class="InsuranceBrokerSystem.UI.Views.MasterTable.InsuranceCompaniesList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:local="clr-namespace:InsuranceBrokerSystem.UI"
            mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000" 
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch" >
    
    <UserControl.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Filter By" Style="{StaticResource GroupBoxStyle}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="Name" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtCompanyName" Width="300" Height="28" Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </GroupBox>
        <StackPanel Orientation="Horizontal" Margin="10,10,10,20" Grid.Row="1">
            <Button Content="+ Register New Insurance Company" 
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Padding="15,8" Margin="0,0,10,0" Background="{StaticResource SaveButtonColor}" Click="RegisterNewInsuranceCompany_Click"/>

        </StackPanel>

        <!--<GroupBox Header="Insurance Companies List" Grid.Row="1" Style="{StaticResource GroupBoxStyle}">-->
        <StackPanel Grid.Row="2">
            <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8">
                <DockPanel>
                    <TextBlock Text="Insurance Companies List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="Refresh 🔄" HorizontalAlignment="Right" Background="#3498DB" Padding="10,2" Foreground="White" Click="btnRefresh_Click"/>
                </DockPanel>
            </Border>
            <DataGrid x:Name="CompaniesGrid" ItemsSource="{Binding InsuranceCompanies}" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="2*" Visibility="Collapsed"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" ElementStyle="{StaticResource StatusColumnStyle}"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding CompanyName}" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Tele." Binding="{Binding Tele}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    <DataGridTextColumn Header="VAT No." Binding="{Binding VATNo}" Width="100"/>
                    <DataGridTextColumn Header="CR No" Binding="{Binding CRNo}" Width="2*"/>
                    <DataGridTextColumn Header="Abbreviation" Binding="{Binding Abbreviation}" Width="100"/>

                    <DataGridTemplateColumn Header="Edit" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Name="btnEdit" Content="Edit" Style="{StaticResource SecondaryButtonStyle}"  CommandParameter="{Binding}" Margin="2" Click="btnEdit_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Delete" Width="80" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete" Style="{StaticResource GridDeleteButton}" Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Grid Grid.Row="3" Margin="10,15,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Results found: " Foreground="Blue" FontWeight="Bold"/>
                <TextBlock Text="{Binding InsuranceCompanies.Count, FallbackValue=00}" Foreground="Blue" FontWeight="Bold"/>
            </StackPanel>

            <Button x:Name="Close" Content="Close" HorizontalAlignment="Right" Width="100" Margin="10"
                    Background="{StaticResource AccentBrush}" 
                    Style="{StaticResource {x:Type Button}}" Click="btnClose_Click" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>