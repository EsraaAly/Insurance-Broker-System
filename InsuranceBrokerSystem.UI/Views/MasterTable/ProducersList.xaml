<UserControl x:Class="InsuranceBrokerSystem.UI.Views.MasterTable.ProducersList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:local="clr-namespace:InsuranceBrokerSystem.UI"
                mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000" 
                     HorizontalContentAlignment="Stretch"
                     VerticalContentAlignment="Stretch" >
    <UserControl.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10,15,0,15">
            <Button Content="+ Register New Producer" Style="{StaticResource SecondaryButtonStyle}" Background="{StaticResource SaveButtonColor}" Margin="0,0,10,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Border Background="#0D3559" CornerRadius="8,8,0,0" Padding="15,8">
                <DockPanel>
                    <TextBlock Text="Producers List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="Refresh 🔄" HorizontalAlignment="Right" Background="#3498DB" Padding="10,2" Foreground="White" Click ="BtnRefresh_Click"/>
                </DockPanel>
            </Border>
            <DataGrid ItemsSource="{Binding Producers}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No." Binding="{Binding ProducerId}" Width="50"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Tele." Binding="{Binding Telephone}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                    <DataGridTextColumn Header="ID Info." Binding="{Binding IdInfo}" Width="1*"/>
                    <DataGridTextColumn Header="Acc No." Binding="{Binding AccountNo}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="Count: 00" Foreground="Blue" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Close" HorizontalAlignment="Right" Width="100" Style="{StaticResource {x:Type Button}}" Background="{StaticResource AccentBrush}"/>
        </Grid>
    </Grid>
</UserControl>